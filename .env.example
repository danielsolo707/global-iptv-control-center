NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by GitHub Actions workers (same project URL, no NEXT_PUBLIC_ prefix).
SUPABASE_URL=https://your-project.supabase.co
# Optional local/server deployment path for manual FFprobe stream validation.
FFPROBE_PATH=ffprobe
